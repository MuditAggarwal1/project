# Copy this file to .env and fill in your values
# Command: copy .env.example .env  (Windows)
#          cp .env.example .env    (Mac/Linux)
# NEVER commit .env to version control

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Your Salesforce Connected App / External Client App Consumer Key
VITE_SF_CLIENT_ID=your_consumer_key_here

# Must exactly match the Callback URL set in your Salesforce Connected App
VITE_SF_REDIRECT_URI=http://localhost:3000

# ── OPTIONAL (defaults shown) ─────────────────────────────────────────────────

# Change to https://test.salesforce.com for Sandbox orgs
VITE_SF_LOGIN_URL=https://login.salesforce.com

# URL of the local proxy server (server.js) — don't change for local dev
VITE_PROXY_URL=http://localhost:3001
